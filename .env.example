# ─── Shinsei Pricing — variáveis de ambiente ──────────────────────────────────
# Copie para .env localmente e configure no painel do Railway em produção.
# NUNCA versione o arquivo .env com valores reais.

# ── Segurança ─────────────────────────────────────────────────────────────────
API_KEY=coloque_uma_chave_segura_aqui
API_KEY_HABILITADO=true

# ── Shopify ───────────────────────────────────────────────────────────────────
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_SHOP=pknw4n-eg

# ── Motor de Frete ────────────────────────────────────────────────────────────
FRETE_SUBSIDIO_POR_ITEM=8.0
FRETE_CEP_ORIGEM=06036003
FRETE_CALLBACK_URL=https://SEU-DOMINIO.railway.app/frete/shopify-callback

# ── Melhor Envio ──────────────────────────────────────────────────────────────
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_SANDBOX=false

# ── Bling (preenchido automaticamente via OAuth — não precisa setar manualmente)
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=https://SEU-DOMINIO.railway.app/bling/callback
BLING_WEBHOOK_SECRET=

# ── Amazon (opcional) ─────────────────────────────────────────────────────────
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_SELLER_ID=

# ── Scheduler ─────────────────────────────────────────────────────────────────
SCHEDULER_ATIVO=true
SCHEDULER_INTERVALO=300

# ── Logs ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_CONSOLE=true

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
