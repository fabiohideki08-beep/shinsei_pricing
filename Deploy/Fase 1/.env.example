# ─────────────────────────────────────────────────────────────
# Shinsei Pricing — variáveis de ambiente
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA versione o arquivo .env com valores reais.
# ─────────────────────────────────────────────────────────────

# ── Bling OAuth ───────────────────────────────────────────────
BLING_CLIENT_ID=SEU_CLIENT_ID_AQUI
BLING_CLIENT_SECRET=SEU_CLIENT_SECRET_AQUI
BLING_REDIRECT_URI=https://seu-dominio.com/bling/callback

# ── Mercado Livre OAuth ───────────────────────────────────────
ML_APP_ID=SEU_APP_ID_AQUI
ML_CLIENT_SECRET=SEU_CLIENT_SECRET_ML_AQUI
ML_REDIRECT_URI=https://seu-dominio.com/ml/callback

# ── API Key (autenticação dos endpoints — Fase 2) ─────────────
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=GERE_UMA_CHAVE_SEGURA_AQUI

# ── Scheduler ────────────────────────────────────────────────
# Intervalo em segundos entre cada ciclo de atualização automática
SCHEDULER_INTERVALO=300

# ── Banco de dados (Fase 1: SQLite, Fase 4: troque para PostgreSQL) ──
# SQLite (padrão — deixe vazio para usar data/shinsei.db)
DATABASE_URL=sqlite:///data/shinsei.db
# PostgreSQL (produção):
# DATABASE_URL=postgresql://usuario:senha@host:5432/shinsei_pricing
